APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.up.railway.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# === DATABASE (MySQL Railway plugin) ===
# Di Railway Variables (BUKAN file ini), pakai SYNTAX REFERENCE double-brace:
#   DB_HOST=${{MySQL.MYSQLHOST}}
#   DB_PORT=${{MySQL.MYSQLPORT}}
#   DB_DATABASE=${{MySQL.MYSQLDATABASE}}
#   DB_USERNAME=${{MySQL.MYSQLUSER}}
#   DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}
# Ganti "MySQL." sesuai nama plugin database kamu di Railway sidebar.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=psi
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# === MIDTRANS ===
# Ambil dari https://dashboard.midtrans.com/settings/config_info
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# === MAIL ===
# PENTING: Railway plan gratis (Free/Trial/Hobby) MEMBLOKIR semua port SMTP
# (25/465/587/2525). Jadi Gmail/Brevo SMTP TIDAK akan jalan di Railway —
# koneksi hang sampai PHP timeout 30 detik. Pakai HTTP API (Resend) di produksi.
#
# --- PRODUCTION (Railway): Resend HTTP API ---
# Set di Railway Variables:
#   MAIL_MAILER=resend
#   RESEND_API_KEY=re_xxxxxxxxxxxx   (ambil dari https://resend.com/api-keys)
#   MAIL_FROM_ADDRESS=onboarding@resend.dev   (tanpa domain sendiri, wajib ini)
#   MAIL_FROM_NAME="Meow Tarot"
# Catatan free tier Resend tanpa domain:
#   - FROM wajib onboarding@resend.dev
#   - TO hanya bisa ke email yang kamu pakai daftar Resend
#   - Mau kirim ke email lain / from domain sendiri -> verifikasi domain di Resend
#
# --- LOCAL (Laragon): Gmail SMTP boleh, karena lokal tidak blok SMTP ---
#   MAIL_MAILER=smtp
#   MAIL_HOST=smtp.gmail.com
#   MAIL_PORT=587
#   MAIL_USERNAME=youremail@gmail.com
#   MAIL_PASSWORD=app-password-16-karakter
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
RESEND_API_KEY=
MAIL_FROM_ADDRESS="onboarding@resend.dev"
MAIL_FROM_NAME="Meow Tarot"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
